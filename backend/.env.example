# ============================================================
# Aithera - Configuración de Variables de Entorno (V0.2)
# Copia este archivo a ".env" en la carpeta backend/ y rellena
# las claves que quieras usar. No subas .env a ningún repositorio.
# ============================================================

# --- Proveedor activo al arrancar (si la BD está vacía) ---
# Opciones: ollama | minimax | openai | anthropic | gemini | deepseek | grok | openrouter
AI_PROVIDER=minimax

# --- MiniMax (recomendado) ---
MINIMAX_API_KEY=your_minimax_key_here
MINIMAX_MODEL=MiniMax-M2.7

# --- ElevenLabs TTS ---
# Obtén una key gratis en https://elevenlabs.io/app/sign-up
ELEVENLABS_API_KEY=your_elevenlabs_key_here

# --- Otros proveedores (opcionales) ---
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-5.1
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-6
# GEMINI_API_KEY=...
# GEMINI_MODEL=gemini-3.1-pro-preview
# DEEPSEEK_API_KEY=...
# DEEPSEEK_MODEL=deepseek-v4-flash
# GROK_API_KEY=xai-...
# GROK_MODEL=grok-4.3

# --- Ollama (local, sin API key) ---
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3
