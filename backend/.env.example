# Aithera Backend - Variables de entorno
# Copia este archivo como ".env" y completa los valores reales.
# NUNCA subas el archivo ".env" real a git (ya está en .gitignore).

# --- General ---
DEBUG=false

# --- Proveedor de IA activo por defecto ---
# Valores válidos hoy: ollama | openai | anthropic
# (Fase 2 del roadmap añadirá: minimax | gemini | openrouter | deepseek | grok)
AI_PROVIDER=ollama
DEFAULT_MODEL=llama3

# --- Ollama (local, no requiere API key) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# --- OpenAI ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4

# --- Anthropic ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-opus-20240229

# --- Base de datos ---
# Nota: este valor NO se usa actualmente (ver app/db/database.py, que calcula
# la ruta de forma fija en %APPDATA%/Aithera/aithera.db). Se deja documentado
# aquí porque app/core/config.py sí lo lee; ver Fase 0 - Tarea "Documentar
# ambigüedad de doble base de datos" para más contexto.
DATABASE_URL=sqlite:///./aithera.db
